# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Токен от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Твой Telegram user ID (можно узнать у @userinfobot)
# Несколько ID через запятую: 123456,789012
ADMIN_IDS=your_telegram_id_here

# ── Server ────────────────────────────────────────────────────────────────────
# Секретный ключ для внутренних запросов бота к серверу
# Придумай любую длинную строку
INTERNAL_SECRET=change_this_to_a_long_random_string

# URL сервера (бот обращается к нему)
# Локально: http://localhost:8000
# На хостинге: https://your-domain.com
SERVER_URL=http://localhost:8000

# Путь к файлу базы данных
DB_PATH=keys.db
